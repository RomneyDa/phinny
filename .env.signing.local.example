# Copy to .env.signing.local (gitignored) and fill in to sign/notarize locally.
# In CI these are provided as GitHub Actions secrets instead (see
# .github/workflows/release.yml). Same approach as the sibling Spurkle app.

# Developer ID Application signing identity, exactly as shown by:
#   security find-identity -v -p codesigning
export DEVELOPER_ID_APPLICATION='Developer ID Application: DALLIN BRUCE ROMNEY (XBMN675A5N)'

# Apple notarization credentials.
export APPLE_ID=''
export APPLE_TEAM_ID='XBMN675A5N'
export APPLE_APP_SPECIFIC_PASSWORD=''

# Optional: a stable identity for *local dev* builds (scripts/build-app.sh).
# Defaults to DEVELOPER_ID_APPLICATION, then ad-hoc ("-") if unset. A stable
# identity keeps file permissions / TCC prompts consistent across rebuilds.
export DEV_SIGN_IDENTITY='Developer ID Application: DALLIN BRUCE ROMNEY (XBMN675A5N)'
